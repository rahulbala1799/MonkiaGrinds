# Gmail account that sends the notification. Use a Google "App Password", not your normal password
# (Google Account → Security → 2-Step Verification → App passwords).
GMAIL_USER=monikagrinds@gmail.com
GMAIL_PASS=

# Inbox for enquiries. If unset, Gmail deliveries use youraddress+website@gmail.com (same inbox).
# CONTACT_TO=monikagrinds@gmail.com

# --- Optional: log enquiries to Google Sheets (same GCP project: enable "Google Sheets API") ---
# Create a service account → JSON key. Share the spreadsheet (Editor) with the service account email.
# ID from: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
# GOOGLE_SHEET_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Vercel: paste the private key with real newlines replaced by the two chars \n
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# Tab/columns (default Sheet1!A:K). Row 1: Timestamp | Parent | Email | Phone | Address | Student | School | Level | Subjects | Hear about | Message
# GOOGLE_SHEET_RANGE=Sheet1!A:K
